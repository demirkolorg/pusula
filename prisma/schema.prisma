  CUMHURIYET_BASSAVCILIGI
  ASLIYE_HUKUK_MAHKEMESI
  SULH_HUKUK_MAHKEMESI
  ASLIYE_CEZA_MAHKEMESI
  SULH_CEZA_MAHKEMESI
  ICRA_MUDURLUGU
  NOTERLIK
  BARO_TEMSILCILIGI
  CEZAEVI
  DENETIMLI_SERBESTLIK
  ADLI_TIP

