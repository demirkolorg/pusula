model Birim {
  id                String          @id @default(uuid()) @db.Uuid
  ad                String?
  kisa_ad           String?
  kategori          BirimKategorisi
  tip               BirimTipi
  il                String?
  ilce              String?
  logo_url          String?
  aktif             Boolean         @default(true)
  silindi_mi        Boolean         @default(false)
  silinme_zamani    DateTime?
  olusturma_zamani  DateTime        @default(now())
  guncelleme_zamani DateTime        @updatedAt

  kullanicilar    Kullanici[]
  proje_birimleri ProjeBirimi[]
  liste_birimleri ListeBirimi[]
  kart_birimleri  KartBirimi[]

  // ADR-0017: global arama (tsvector + GIN) — trigger ile otomatik güncellenir.
  arama_vektoru Unsupported("tsvector")?

  @@index([kategori])
  @@index([tip])
  @@index([silindi_mi])
  @@index([arama_vektoru], type: Gin)
  // ADR-0017: pg_trgm fuzzy fallback (yazım hatası toleransı)
  @@index([ad(ops: raw("gin_trgm_ops"))], type: Gin, map: "Birim_ad_trgm_idx")
}

// ============================================================
// Kullanıcı & RBAC
// ============================================================

enum KullaniciOnayDurumu {
  BEKLIYOR
  ONAYLANDI
  REDDEDILDI
}

model Kullanici {
  id                String              @id @default(uuid()) @db.Uuid
  birim_id          String?             @db.Uuid
  email             String              @unique
  parola_hash       String
  ad                String
  soyad             String
  tc_kimlik_no      String?             @unique
  telefon           String?
  unvan             String?
  aktif             Boolean             @default(true)
  onay_durumu       KullaniciOnayDurumu @default(BEKLIYOR)
  onaylayan_id      String?             @db.Uuid
  onay_zamani       DateTime?
  red_sebebi        String?
  email_dogrulandi  DateTime?
  son_giris_zamani  DateTime?
  silindi_mi        Boolean             @default(false)
  silinme_zamani    DateTime?
  olusturma_zamani  DateTime            @default(now())
  guncelleme_zamani DateTime            @updatedAt

  birim               Birim?           @relation(fields: [birim_id], references: [id])
  roller              KullaniciRol[]
  proje_yetkileri     ProjeYetkilisi[]
  liste_yetkileri     ListeYetkilisi[]
  kart_yetkileri      KartYetkilisi[]
  olusturduklari      Proje[]          @relation("ProjeOlusturan")
  yorumlar            Yorum[]          @relation("YorumYazan")
  eklentiler          Eklenti[]        @relation("EklentiYukleyen")
  tamamlanan_maddeler KontrolMaddesi[] @relation("KontrolTamamlayan")
  atanan_maddeler     KontrolMaddesi[] @relation("KontrolAtanan")
  tamamladigi_kartlar Kart[]           @relation("KartTamamlayan")
  bildirimler         Bildirim[]       @relation("BildirimAlici")
  ureten_bildirimler  Bildirim[]       @relation("BildirimUreten")

  // ADR-0017: global arama (tsvector + GIN) — trigger ile otomatik güncellenir.
  arama_vektoru Unsupported("tsvector")?

  @@index([birim_id])
  @@index([email])
  @@index([onay_durumu])
  @@index([silindi_mi])
  @@index([arama_vektoru], type: Gin)
  // ADR-0017: pg_trgm fuzzy fallback
  @@index([ad(ops: raw("gin_trgm_ops"))], type: Gin, map: "Kullanici_ad_trgm_idx")
  @@index([soyad(ops: raw("gin_trgm_ops"))], type: Gin, map: "Kullanici_soyad_trgm_idx")
}

enum IzinKategorisi {
  PROJE
  LISTE
  KART
  KULLANICI
  BIRIM
  ROL
  AUDIT
  AYAR
}

model Rol {
  id                String   @id @default(uuid()) @db.Uuid
  kod               String   @unique
  ad                String
  aciklama          String?
  sistem_rolu       Boolean  @default(false)
  // ADR-0013: izinler her güncellendiğinde +1 — JWT eski versiyonla geldiğinde
  // istemci client'ı bilgilendirip yenilemesi için kullanılır.
  izin_versiyonu    Int      @default(1)
  olusturma_zamani  DateTime @default(now())
  guncelleme_zamani DateTime @updatedAt

  kullanicilar KullaniciRol[]
  izinler      RolIzin[]
}

model Izin {
  id               String         @id @default(uuid()) @db.Uuid
  kod              String         @unique
  ad               String
  aciklama         String?
  kategori         IzinKategorisi
  // ADR-0014: UI accordion alt-grup başlığı (yetkili, kapak, tarih, yorum, ...)
  // null → "temel/genel" (alt-grup yok).
  alt_kategori     String?
  olusturma_zamani DateTime       @default(now())

  roller RolIzin[]

  @@index([kategori])
  @@index([alt_kategori])
}

model RolIzin {
  rol_id  String @db.Uuid
  izin_id String @db.Uuid

  rol  Rol  @relation(fields: [rol_id], references: [id], onDelete: Cascade)
  izin Izin @relation(fields: [izin_id], references: [id], onDelete: Cascade)

  @@id([rol_id, izin_id])
  @@index([izin_id])
}

model KullaniciRol {
  kullanici_id String   @db.Uuid
  rol_id       String   @db.Uuid
  atama_zamani DateTime @default(now())
  atayan_id    String?  @db.Uuid

  kullanici Kullanici @relation(fields: [kullanici_id], references: [id], onDelete: Cascade)
  rol       Rol       @relation(fields: [rol_id], references: [id], onDelete: Cascade)

  @@id([kullanici_id, rol_id])
  @@index([rol_id])
}

// ============================================================
// Audit Log (Skill 1.5/B — Çekirdek düzeyinde değişiklik izleme)
// ============================================================

model AktiviteLogu {
  id           BigInt   @id @default(autoincrement())
  zaman        DateTime @default(now())
  kullanici_id String?  @db.Uuid
  oturum_id    String?
  ip           String?
  user_agent   String?
  request_id   String?
  http_metod   String?
  http_yol     String?
  islem        String
  kaynak_tip   String
  kaynak_id    String?
  eski_veri    Json?
  yeni_veri    Json?
  diff         Json?
  meta         Json?
  sebep        String?

  @@index([kaynak_tip, kaynak_id, zaman(sort: Desc)])
  @@index([kullanici_id, zaman(sort: Desc)])
  @@index([zaman(sort: Desc)])
  @@index([islem])
  @@map("aktivite_logu")
}

// ============================================================
// Hata Logu (Skill 1.5/C — Çekirdek düzeyinde error tracking)
// ============================================================

model HataLogu {
  id               BigInt   @id @default(autoincrement())
  zaman            DateTime @default(now())
  seviye           String
  taraf            String
  request_id       String?
  kullanici_id     String?  @db.Uuid
  oturum_id        String?
  ip               String?
  user_agent       String?
  url              String?
  hata_tipi        String?
  mesaj            String
  stack            String?
  http_metod       String?
  http_durum       Int?
  istek_govdesi    Json?
  istek_basliklari Json?
  ekstra           Json?
  cozuldu_mu       Boolean  @default(false)
  cozum_notu       String?

  @@index([zaman(sort: Desc)])
  @@index([seviye, zaman(sort: Desc)])
  @@index([cozuldu_mu, zaman(sort: Desc)])
  @@index([request_id])
  @@map("hata_logu")
}

// ============================================================
// Davet & Parola Sıfırlama Token'ları
// ============================================================

model DavetTokeni {
  id               String    @id @default(uuid()) @db.Uuid
  token            String    @unique
  email            String
  rol_id           String?   @db.Uuid
  birim_id         String?   @db.Uuid
  davet_eden_id    String    @db.Uuid
  son_kullanma     DateTime
  kullanildi_mi    Boolean   @default(false)
  kullanim_zamani  DateTime?
  olusturma_zamani DateTime  @default(now())

  proje_baglamlari DavetProjeBaglami[]
  liste_baglamlari DavetListeBaglami[]
  kart_baglamlari  DavetKartBaglami[]

  @@index([token])
  @@index([email])
  @@index([birim_id])
}

// ADR-0010/0013 — Davet kabul edildiğinde kaynak'a göre yetkili kayıtları açılır:
// proje_baglamlari → ProjeYetkilisi, liste_baglamlari → ListeYetkilisi,
// kart_baglamlari → KartYetkilisi. Üçü de davet expire/use'da onDelete: Cascade
// ile temizlenir (sync loop gerekmez).
model DavetProjeBaglami {
  id               String   @id @default(uuid()) @db.Uuid
  davet_id         String   @db.Uuid
  proje_id         String   @db.Uuid
  olusturma_zamani DateTime @default(now())

  davet DavetTokeni @relation(fields: [davet_id], references: [id], onDelete: Cascade)
  proje Proje       @relation(fields: [proje_id], references: [id], onDelete: Cascade)

  @@unique([davet_id, proje_id])
  @@index([proje_id])
}

model DavetListeBaglami {
  id               String   @id @default(uuid()) @db.Uuid
  davet_id         String   @db.Uuid
  liste_id         String   @db.Uuid
  olusturma_zamani DateTime @default(now())

  davet DavetTokeni @relation(fields: [davet_id], references: [id], onDelete: Cascade)
  liste Liste       @relation(fields: [liste_id], references: [id], onDelete: Cascade)

  @@unique([davet_id, liste_id])
  @@index([liste_id])
}

model DavetKartBaglami {
  id               String   @id @default(uuid()) @db.Uuid
  davet_id         String   @db.Uuid
  kart_id          String   @db.Uuid
  olusturma_zamani DateTime @default(now())

  davet DavetTokeni @relation(fields: [davet_id], references: [id], onDelete: Cascade)
  kart  Kart        @relation(fields: [kart_id], references: [id], onDelete: Cascade)

  @@unique([davet_id, kart_id])
  @@index([kart_id])
}

model SifirlamaTokeni {
  id               String   @id @default(uuid()) @db.Uuid
  token            String   @unique
  kullanici_id     String   @db.Uuid
  son_kullanma     DateTime
  kullanildi_mi    Boolean  @default(false)
  olusturma_zamani DateTime @default(now())

  @@index([token])
  @@index([kullanici_id])
}

// ============================================================
// Proje · Liste · Kart (S3)
// Plan: docs/plan.md Bölüm 2 (domain) + Bölüm 7 (S3)
// ============================================================

model Proje {
  id                String    @id @default(uuid()) @db.Uuid
  ad                String
  aciklama          String?
  kapak_renk        String? // tema token'ı: "primary" | "secondary" | "tertiary"
  kapak_ikon        String? // lucide-react ikon ismi (kebab-case) — ADR-0011
  kapak_dosya_id    String?   @db.Uuid
  yildizli_mi       Boolean   @default(false)
  arsiv_mi          Boolean   @default(false)
  arsiv_zamani      DateTime?
  silindi_mi        Boolean   @default(false)
  silinme_zamani    DateTime?
  sira              String // LexoRank — proje listesinde sıralama
  olusturan_id      String?   @db.Uuid
  olusturma_zamani  DateTime  @default(now())
  guncelleme_zamani DateTime  @updatedAt

  olusturan         Kullanici?          @relation("ProjeOlusturan", fields: [olusturan_id], references: [id])
  yetkililer        ProjeYetkilisi[]
  birimler          ProjeBirimi[]
  listeler          Liste[]
  etiketler         Etiket[]
  bekleyen_davetler DavetProjeBaglami[]

  // ADR-0017: global arama (tsvector + GIN) — trigger ile otomatik güncellenir.
  arama_vektoru Unsupported("tsvector")?

  @@index([silindi_mi, arsiv_mi])
  @@index([sira])
  @@index([arama_vektoru], type: Gin)
  // ADR-0017: pg_trgm fuzzy fallback
  @@index([ad(ops: raw("gin_trgm_ops"))], type: Gin, map: "Proje_ad_trgm_idx")
}

model ProjeYetkilisi {
  proje_id       String   @db.Uuid
  kullanici_id   String   @db.Uuid
  eklenme_zamani DateTime @default(now())

  proje     Proje     @relation(fields: [proje_id], references: [id], onDelete: Cascade)
  kullanici Kullanici @relation(fields: [kullanici_id], references: [id], onDelete: Cascade)

  @@id([proje_id, kullanici_id])
  @@index([kullanici_id])
  @@map("ProjeUyesi")
}

model ProjeBirimi {
  proje_id       String   @db.Uuid
  birim_id       String   @db.Uuid
  eklenme_zamani DateTime @default(now())

  proje Proje @relation(fields: [proje_id], references: [id], onDelete: Cascade)
  birim Birim @relation(fields: [birim_id], references: [id])

  @@id([proje_id, birim_id])
  @@index([birim_id])
}

enum ListeTipi {
  // Kullanıcı tarafından oluşturulan, normal kart taşıyıcı liste
  NORMAL
  // Sistem listesi: her projede otomatik tek tane; arşivlenen kartları barındırır.
  // ADR-0009 — silinemez/yeniden adlandırılamaz/sıralanamaz.
  ARSIV
}

model Liste {
  id                String    @id @default(uuid()) @db.Uuid
  proje_id          String    @db.Uuid
  ad                String
  sira              String // LexoRank — proje içi liste sırası (Arşiv: "ZZZZ")
  tip               ListeTipi @default(NORMAL)
  arsiv_mi          Boolean   @default(false)
  wip_limit         Int?
  olusturma_zamani  DateTime  @default(now())
  guncelleme_zamani DateTime  @updatedAt

  proje             Proje               @relation(fields: [proje_id], references: [id], onDelete: Cascade)
  kartlar           Kart[]
  yetkililer        ListeYetkilisi[]
  birimler          ListeBirimi[]
  bekleyen_davetler DavetListeBaglami[]

  // ADR-0017: global arama (tsvector + GIN) — trigger ile otomatik güncellenir.
  arama_vektoru Unsupported("tsvector")?

  @@index([proje_id, sira])
  @@index([proje_id, arsiv_mi])
  @@index([proje_id, tip])
  @@index([arama_vektoru], type: Gin)
  // ADR-0017: pg_trgm fuzzy fallback
  @@index([ad(ops: raw("gin_trgm_ops"))], type: Gin, map: "Liste_ad_trgm_idx")
}

model ListeYetkilisi {
  liste_id       String   @db.Uuid
  kullanici_id   String   @db.Uuid
  eklenme_zamani DateTime @default(now())

  liste     Liste     @relation(fields: [liste_id], references: [id], onDelete: Cascade)
  kullanici Kullanici @relation(fields: [kullanici_id], references: [id], onDelete: Cascade)

  @@id([liste_id, kullanici_id])
  @@index([kullanici_id])
  @@map("ListeUyesi")
}

model ListeBirimi {
  liste_id       String   @db.Uuid
  birim_id       String   @db.Uuid
  eklenme_zamani DateTime @default(now())

  liste Liste @relation(fields: [liste_id], references: [id], onDelete: Cascade)
  birim Birim @relation(fields: [birim_id], references: [id])

  @@id([liste_id, birim_id])
  @@index([birim_id])
}

model Kart {
  id                    String    @id @default(uuid()) @db.Uuid
  liste_id              String    @db.Uuid
  baslik                String
  aciklama              String?
  sira                  String // LexoRank — liste içi kart sırası
  kapak_renk            String?
  kapak_dosya_id        String?   @db.Uuid
  baslangic             DateTime?
  bitis                 DateTime?
  // Trello tarzı — kart bütün olarak tamamlandı işareti. Kontrol listesi
  // maddelerinden bağımsız: kullanıcı manuel toggle eder. tamamlanma_zamani
  // raporlama/sıralama, tamamlayan_id audit için.
  tamamlandi_mi      Boolean   @default(false)
  tamamlanma_zamani  DateTime?
  tamamlayan_id      String?   @db.Uuid
  arsiv_mi              Boolean   @default(false)
  // ADR-0009 — kart arşivlenmeden önceki listenin id'si; geri yükleme için.
  arsiv_oncesi_liste_id String?   @db.Uuid
  arsiv_zamani          DateTime?
  silindi_mi            Boolean   @default(false)
  silinme_zamani        DateTime?
  olusturan_id          String?   @db.Uuid
  olusturma_zamani      DateTime  @default(now())
  guncelleme_zamani     DateTime  @updatedAt

  liste             Liste              @relation(fields: [liste_id], references: [id], onDelete: Cascade)
  tamamlayan        Kullanici?         @relation("KartTamamlayan", fields: [tamamlayan_id], references: [id])
  yetkililer        KartYetkilisi[]
  etiketler         KartEtiket[]
  birimler          KartBirimi[]
  yorumlar          Yorum[]
  eklentiler        Eklenti[]
  kontrol_listeleri KontrolListesi[]
  bekleyen_davetler DavetKartBaglami[]

  // ADR-0017: global arama (tsvector + GIN) — trigger ile otomatik güncellenir.
  arama_vektoru Unsupported("tsvector")?

  @@index([liste_id, sira])
  @@index([liste_id, silindi_mi, arsiv_mi])
  @@index([liste_id, tamamlandi_mi])
  @@index([bitis])
  @@index([arama_vektoru], type: Gin)
  // ADR-0017: pg_trgm fuzzy fallback
  @@index([baslik(ops: raw("gin_trgm_ops"))], type: Gin, map: "Kart_baslik_trgm_idx")
}

model KartBirimi {
  kart_id        String   @db.Uuid
  birim_id       String   @db.Uuid
  eklenme_zamani DateTime @default(now())

  kart  Kart  @relation(fields: [kart_id], references: [id], onDelete: Cascade)
  birim Birim @relation(fields: [birim_id], references: [id])

  @@id([kart_id, birim_id])
  @@index([birim_id])
}

model Etiket {
  id               String   @id @default(uuid()) @db.Uuid
  proje_id         String   @db.Uuid
  ad               String
  renk             String // hex
  olusturma_zamani DateTime @default(now())

  proje       Proje        @relation(fields: [proje_id], references: [id], onDelete: Cascade)
  kart_baglar KartEtiket[]

  // ADR-0017: global arama (tsvector + GIN) — trigger ile otomatik güncellenir.
  arama_vektoru Unsupported("tsvector")?

  @@unique([proje_id, ad])
  @@index([proje_id])
  @@index([arama_vektoru], type: Gin)
  // ADR-0017: pg_trgm fuzzy fallback
  @@index([ad(ops: raw("gin_trgm_ops"))], type: Gin, map: "Etiket_ad_trgm_idx")
}

model KartEtiket {
  kart_id   String @db.Uuid
  etiket_id String @db.Uuid

  kart   Kart   @relation(fields: [kart_id], references: [id], onDelete: Cascade)
  etiket Etiket @relation(fields: [etiket_id], references: [id], onDelete: Cascade)

  @@id([kart_id, etiket_id])
  @@index([etiket_id])
}

model KartYetkilisi {
  kart_id        String   @db.Uuid
  kullanici_id   String   @db.Uuid
  eklenme_zamani DateTime @default(now())

  kart      Kart      @relation(fields: [kart_id], references: [id], onDelete: Cascade)
  kullanici Kullanici @relation(fields: [kullanici_id], references: [id], onDelete: Cascade)

  @@id([kart_id, kullanici_id])
  @@index([kullanici_id])
  @@map("KartUyesi")
}

// ============================================================
// Yorum · Eklenti · Kontrol Listesi (S4)
// Plan: docs/plan.md Bölüm 5 (Kart Detay - Trello features)
// Kurallar: SKILL.md Kural 70 (XSS / DOMPurify), 72 (Upload mime+boyut),
// 90 (5 katman), 107 (optimistic), 138 (granular permissions).
// ============================================================

model Yorum {
  id                String    @id @default(uuid()) @db.Uuid
  kart_id           String    @db.Uuid
  yazan_id          String    @db.Uuid
  // Markdown — server'da DOMPurify ile sanitize edilip render edilir.
  // @mention metnin içinde "@uuid" formatında kalır; parse ile Bildirim üretilir.
  icerik            String
  duzenlendi_mi     Boolean   @default(false)
  silindi_mi        Boolean   @default(false)
  silinme_zamani    DateTime?
  yanit_yorum_id    String?   @db.Uuid
  olusturma_zamani  DateTime  @default(now())
  guncelleme_zamani DateTime  @updatedAt

  kart        Kart      @relation(fields: [kart_id], references: [id], onDelete: Cascade)
  yazan       Kullanici @relation("YorumYazan", fields: [yazan_id], references: [id])
  yanit_yorum Yorum?    @relation("YorumYanit", fields: [yanit_yorum_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  yanitlar    Yorum[]   @relation("YorumYanit")

  // ADR-0017: global arama (tsvector + GIN) — trigger ile otomatik güncellenir.
  arama_vektoru Unsupported("tsvector")?

  @@index([kart_id, silindi_mi, olusturma_zamani(sort: Desc)])
  @@index([yazan_id])
  @@index([arama_vektoru], type: Gin)
  // ADR-0017: pg_trgm fuzzy fallback
  @@index([icerik(ops: raw("gin_trgm_ops"))], type: Gin, map: "Yorum_icerik_trgm_idx")
}

model Eklenti {
  id                String    @id @default(uuid()) @db.Uuid
  kart_id           String    @db.Uuid
  yukleyen_id       String    @db.Uuid
  ad                String // orijinal dosya adı
  mime              String
  boyut             Int // bytes — Kural 72: limit server'da kontrol edilir
  depolama_yolu     String // MinIO key — presigned URL ile servis edilir
  silindi_mi        Boolean   @default(false)
  silinme_zamani    DateTime?
  olusturma_zamani  DateTime  @default(now())
  guncelleme_zamani DateTime  @updatedAt

  kart     Kart      @relation(fields: [kart_id], references: [id], onDelete: Cascade)
  yukleyen Kullanici @relation("EklentiYukleyen", fields: [yukleyen_id], references: [id])

  // ADR-0017: global arama (tsvector + GIN) — trigger ile otomatik güncellenir.
  arama_vektoru Unsupported("tsvector")?

  @@index([kart_id, silindi_mi, olusturma_zamani(sort: Desc)])
  @@index([arama_vektoru], type: Gin)
  // ADR-0017: pg_trgm fuzzy fallback
  @@index([ad(ops: raw("gin_trgm_ops"))], type: Gin, map: "Eklenti_ad_trgm_idx")
}

model KontrolListesi {
  id                String   @id @default(uuid()) @db.Uuid
  kart_id           String   @db.Uuid
  ad                String
  sira              String // LexoRank — kart içi liste sırası
  olusturma_zamani  DateTime @default(now())
  guncelleme_zamani DateTime @updatedAt

  kart     Kart             @relation(fields: [kart_id], references: [id], onDelete: Cascade)
  maddeler KontrolMaddesi[]

  @@index([kart_id, sira])
}

model KontrolMaddesi {
  id                 String    @id @default(uuid()) @db.Uuid
  kontrol_listesi_id String    @db.Uuid
  metin              String
  tamamlandi_mi      Boolean   @default(false)
  tamamlama_zamani   DateTime?
  tamamlayan_id      String?   @db.Uuid
  atanan_id          String?   @db.Uuid
  bitis              DateTime?
  sira               String // LexoRank — liste içi madde sırası
  olusturma_zamani   DateTime  @default(now())
  guncelleme_zamani  DateTime  @updatedAt

  kontrol_listesi KontrolListesi @relation(fields: [kontrol_listesi_id], references: [id], onDelete: Cascade)
  tamamlayan      Kullanici?     @relation("KontrolTamamlayan", fields: [tamamlayan_id], references: [id])
  atanan          Kullanici?     @relation("KontrolAtanan", fields: [atanan_id], references: [id])

  // ADR-0017: global arama (tsvector + GIN) — trigger ile otomatik güncellenir.
  arama_vektoru Unsupported("tsvector")?

  @@index([kontrol_listesi_id, sira])
  @@index([atanan_id])
  @@index([arama_vektoru], type: Gin)
  // ADR-0017: pg_trgm fuzzy fallback
  @@index([metin(ops: raw("gin_trgm_ops"))], type: Gin, map: "KontrolMaddesi_metin_trgm_idx")
}

// ============================================================
// Bildirim (S5 — kalıcı in-app bildirim merkezi)
// Plan: docs/plan.md Bölüm 1.5/E + Bölüm 7 S5
// Kurallar: SKILL.md Kural 63 (kalıcı → Bildirim, geçici → Sonner)
// ============================================================

enum BildirimTipi {
  // Yorum içinde @mention edildi
  YORUM_MENTION
  // Karta üye olarak atandı
  KART_YETKILI_ATAMA @map("KART_UYE_ATAMA")
  // Kontrol maddesi atandı
  MADDE_ATAMA
  // Kart bitiş tarihi yaklaşıyor / geçti
  BITIS_YAKLASIYOR
  BITIS_GECTI
  // Karta yorum yazıldı (kart üyelerine)
  YORUM_EKLENDI
  // Karta eklenti yüklendi (kart üyelerine)
  EKLENTI_YUKLENDI
  // Projeye yetkili olarak eklendi
  PROJE_UYE_EKLENDI
  // Projeden yetkili olarak çıkarıldı
  PROJE_UYE_CIKARILDI
  // Kart başka bir listeye taşındı (kart üyelerine)
  KART_DURUM_DEGISTI
  // Kart bitiş tarihi değişti (kart üyelerine)
  KART_BITIS_DEGISTI
  // Atandığın kart silindi
  KART_SILINDI
  // Atandığın kart tamamlandı işaretlendi
  KART_TAMAMLANDI
  // Yetkilisi olduğun bir liste silindi
  LISTE_SILINDI
  // Gönderdiğin davet kabul edildi (davet edene)
  DAVET_KABUL_EDILDI
}

model Bildirim {
  id               BigInt       @id @default(autoincrement())
  alici_id         String       @db.Uuid
  ureten_id        String?      @db.Uuid // sistem bildiriminde null
  tip              BildirimTipi
  // Bildirimle ilişkili kaynak (kart/yorum/eklenti) — derin link için
  kaynak_tip       String?
  kaynak_id        String?      @db.Uuid
  // Öneri: kart_id derin link için her zaman doldurulur (varsa)
  kart_id          String?      @db.Uuid
  proje_id         String?      @db.Uuid
  // TR mesaj — örn "Ahmet kartta sizi etiketledi: 'Lütfen kontrol edin…'"
  // İçerik tetikleyici tarafından dilte üretilir; çevrilmez (i18n v2'de).
  baslik           String
  ozet             String?
  // Ekstra payload (UI için ek bilgi: yorum_id, eklenti_id vb.)
  meta             Json?
  okundu_mu        Boolean      @default(false)
  okuma_zamani     DateTime?
  olusturma_zamani DateTime     @default(now())

  alici  Kullanici  @relation("BildirimAlici", fields: [alici_id], references: [id], onDelete: Cascade)
  ureten Kullanici? @relation("BildirimUreten", fields: [ureten_id], references: [id])

  @@index([alici_id, okundu_mu, olusturma_zamani(sort: Desc)])
  @@index([alici_id, olusturma_zamani(sort: Desc)])
  @@index([kart_id])
}
