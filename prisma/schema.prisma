// Pusula — Kaymakamlık Görev Yönetimi
// Plan: docs/plan.md (Bölüm 3 — Prisma Schema)
// Kurallar: .claude/skills/kontrol/SKILL.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Kurum (ilçedeki tüm kurumların envanteri — düz liste)
// ============================================================

