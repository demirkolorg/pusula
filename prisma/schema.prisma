  ILCE_MILLI_EGITIM_MUDURLUGU
  HALK_EGITIM_MERKEZI
  MESLEKI_EGITIM_MERKEZI
  REHBERLIK_ARASTIRMA_MERKEZI
  ANAOKULU
  ILKOKUL
  ORTAOKUL
  LISE
  ANADOLU_LISESI
  FEN_LISESI
  IMAM_HATIP_LISESI
  MESLEK_LISESI
  OZEL_EGITIM_OKULU
  OGRETMENEVI
  KYK_YURDU
  OZEL_YURT
  UNIVERSITE
  MESLEK_YUKSEKOKULU

