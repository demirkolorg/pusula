  CEVRE_SEHIRCILIK_IMAR
  AFET_ACIL_DURUM
  KULTUR_SPOR_GENCLIK
  DIN_HIZMETLERI
  TICARET_SANAYI
  ISTIHDAM
  BANKA_FINANS
  ASKERLIK
  GUMRUK
  SIVIL_TOPLUM
  BASIN_MEDYA
}

