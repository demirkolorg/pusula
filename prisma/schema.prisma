  YEREL_YONETIM
  EMNIYET_ASAYIS
  ADALET
  EGITIM
  SAGLIK
  MALIYE_VERGI
  TAPU_KADASTRO
  NUFUS_VATANDASLIK
  SOSYAL_HIZMETLER
  TARIM_ORMAN_HAYVANCILIK
  ULASTIRMA_ALTYAPI
  CEVRE_SEHIRCILIK_IMAR
  AFET_ACIL_DURUM
  KULTUR_SPOR_GENCLIK
  DIN_HIZMETLERI
  TICARET_SANAYI
  ISTIHDAM
  BANKA_FINANS
  ASKERLIK
  GUMRUK
  SIVIL_TOPLUM
  BASIN_MEDYA
}

