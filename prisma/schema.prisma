  ILCE_SAGLIK_MUDURLUGU
  DEVLET_HASTANESI
  AGIZ_DIS_SAGLIGI_MERKEZI
  TOPLUM_SAGLIGI_MERKEZI
  AILE_SAGLIGI_MERKEZI
  ACIL_SAGLIK_ISTASYONU
  VEREM_SAVAS_DISPANSERI
  HALK_SAGLIGI_LABORATUVARI
