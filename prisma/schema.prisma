  REHBERLIK_ARASTIRMA_MERKEZI
  ANAOKULU
  ILKOKUL
  ORTAOKUL
  LISE
  ANADOLU_LISESI
  FEN_LISESI
  IMAM_HATIP_LISESI
  MESLEK_LISESI
  OZEL_EGITIM_OKULU
  OGRETMENEVI
  KYK_YURDU
  OZEL_YURT
  UNIVERSITE
  MESLEK_YUKSEKOKULU

  // SAGLIK
  ILCE_SAGLIK_MUDURLUGU
  DEVLET_HASTANESI
  AGIZ_DIS_SAGLIGI_MERKEZI
  TOPLUM_SAGLIGI_MERKEZI
  AILE_SAGLIGI_MERKEZI
  ACIL_SAGLIK_ISTASYONU
  VEREM_SAVAS_DISPANSERI
  HALK_SAGLIGI_LABORATUVARI
  OZEL_HASTANE
